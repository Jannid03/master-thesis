<?xml version='1.0' encoding='UTF-8'?>
<MorpheusModel version="4">
    <Description>
        <Details>This model implements the dynmaics of the NF-KB pathway of the 2015 paper by Mothes et al. It was modified to include the TNF-α pathway for activating IKK and the resulting signaling cascade. Based on this I will conduct multiple stochastic analysis.</Details>
        <Title>Nf-KB 2015 Model + TNF</Title>
    </Description>
    <Space>
        <Lattice class="square">
            <Neighborhood>
                <Order>1</Order>
            </Neighborhood>
            <Size symbol="size" value="200.0, 200.0, 0.0"/>
            <BoundaryConditions>
                <Condition type="periodic" boundary="x"/>
                <Condition type="periodic" boundary="y"/>
