    <CPM>
        <Interaction>
            <Contact type2="macrophage" type1="macrophage" value="1"/>
            <Contact type2="medium" type1="macrophage" value="0.0"/>
        </Interaction>
        <ShapeSurface scaling="norm">
            <Neighborhood>
                <Order>optimal</Order>
            </Neighborhood>
        </ShapeSurface>
        <MonteCarloSampler stepper="edgelist">
            <MCSDuration value="1"/>
            <MetropolisKinetics yield="0.1" temperature="3"/>
            <Neighborhood>
                <Order>optimal</Order>
            </Neighborhood>
        </MonteCarloSampler>
    </CPM>
    <Global>
        <Variable symbol="activator" value="20"/>
        <Variable symbol="flux_in_medium" value="0.0"/>
        <Mapper>
            <Input value="TNFaflux"/>
            <Output symbol-ref="flux_in_medium" mapping="sum"/>
        </Mapper>
    </Global>
</MorpheusModel>
