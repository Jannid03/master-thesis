    </Analysis>
    <CellTypes>
        <CellType name="macrophage" class="biological">
            <System time-step="1.0" solver="Dormand-Prince [adaptive, O(5)]">
                <Constant symbol="a1" name="association of IKBA and IKK" value="1.35"/>
                <Constant symbol="d1" name="dissociation of IKK/IKBA" value="0.075"/>
                <Constant symbol="a4" name="association of IKBA and NF-KB" value="30.0"/>
                <Constant symbol="a7" name="association of NF-KB/IKBA and IKK" value="11.1"/>
                <Constant symbol="a4i" name="association of IKK|IKBAand NF-KB" value="30.0"/>
                <Constant symbol="deg1" name="degradation of IKBA" value="0.12"/>
                <Constant symbol="deg1n" name="degradation of nucleus IKBA_n" value="0.12"/>
                <Constant symbol="r4" name="IKK-dependent degradation of IKBA bound to NF-KB" value="0.36"/>
                <Constant symbol="k1" name="import of cytoplasm NF-KB into nucleus" value="5.4"/>
                <Constant symbol="k2a" name="export of nuclear NF-KB|IKBA into cytoplasm" value="0.828"/>
                <Constant symbol="tp1a" name="import of IKBA into nucleus" value="0.018"/>
                <Constant symbol="a4n" name="association of nucleus IKBA and nucleus NF-KB" value="30.0"/>
                <Constant symbol="tr4a" name="NF-KB-dependent transcription of IKBA mRNA " value="1.386"/>
                <Constant symbol="tr2a" name="constitutive transcription of IKBA mRNA" value="0.0001848"/>
                <Constant symbol="tr3a" name="degradation of IKBA mRNA" value="0.0336"/>
                <Constant symbol="tr1a" name="synthesis of IKBA protein" value="0.2448"/>
                <Constant symbol="ktrans" value="0.0769"/>
                <Constant symbol="s3" value="1.0"/>
                <Constant symbol="t1" value="3.8e-4"/>
                <Constant symbol="s1" value="1.9e-5*1680"/>
                <Constant symbol="s2" value="0.1"/>
                <Constant symbol="s20" value="7.7e-4*60"/>
                <Constant symbol="d0" value="5e-5*60"/>
                <Constant symbol="t9" value="1"/>
                <Constant symbol="t11" value="37.2759372"/>
                <Constant symbol="t4" value="2e-4*60"/>
                <Constant symbol="t7" value="0.15"/>
                <Constant symbol="d20" value="0.01"/>
                <Constant symbol="d6" value="0.223"/>
                <DiffEqn symbol-ref="NFKB">
                    <Expression>r4*IKK_NFKB_IKBA-a4*IKBA*NFKB-a4i*IKK_IKBA*NFKB-k1*NFKB</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="NFKB.n">
                    <Expression>k1*NFKB-a4n*NFKB.n*IKBA.n</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="IKBA.m">
                    <Expression>tr2a+tr4a*NFKB.n^2-tr3a*IKBA.m</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="IKBA">
                    <Expression>-a4*IKBA*NFKB-a1*IKBA*IKK+d1*IKK_IKBA+tr1a*IKBA.m-deg1*IKBA-tp1a*IKBA</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="IKBA.n">
                    <Expression>tp1a*IKBA-a4n*NFKB.n*IKBA.n-deg1n*IKBA.n</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="IKK">
                    <Expression>r4*IKK_NFKB_IKBA-a1*IKK*IKBA+d1*IKK_IKBA-a7*IKK*NFKB_IKBA-d6*IKK+s2*TNFa_TNFR+s3*LPS</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="IKK_IKBA">
                    <Expression>-a4i*IKK_IKBA*NFKB+a1*IKBA*IKK-d1*IKK_IKBA</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="IKK_NFKB_IKBA">
                    <Expression>a4i*IKK_IKBA*NFKB-r4*IKK_NFKB_IKBA+a7*IKK*NFKB_IKBA</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="NFKB_IKBA.n">
                    <Expression>a4n*NFKB.n*IKBA.n-k2a*NFKB_IKBA.n</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="NFKB_IKBA">
                    <Expression>k2a*NFKB_IKBA.n+a4*NFKB*IKBA-a7*IKK*NFKB_IKBA</Expression>
                </DiffEqn>
                <Rule symbol-ref="total_NFKB">
                    <Expression>NFKB+NFKB.n+IKK_NFKB_IKBA+NFKB_IKBA+NFKB_IKBA.n</Expression>
                </Rule>
                <Rule symbol-ref="total_IKK">
                    <Expression>IKK+IKK_IKBA+IKK_NFKB_IKBA</Expression>
                </Rule>
                <!--    <Disabled>
        <DiffEqn symbol-ref="total_IKK">
            <Expression>-ktrans*total_IKK+ktrans*IKKconc</Expression>
        </DiffEqn>
    </Disabled>
-->
                <DiffEqn symbol-ref="LPS">
                    <Expression>-ktrans*LPS + ktrans*stimulus</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="iTNFa">
                    <Expression>-t4*iTNFa+t9*TNFa.m-e1*iTNFa</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="eTNFa">
                    <Expression>TNFaflux+e1*iTNFa-s0*eTNFa*TNFR-s1*TNFa_TNFR-d20*eTNFa</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="TNFR">
                    <Expression>t1*(tmax-TNFR)-s0*eTNFa*TNFR+s1*TNFa_TNFR</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="TNFa_TNFR">
                    <Expression>-s1*TNFa_TNFR+s0*eTNFa*TNFR-s20*TNFa_TNFR</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="TNFR.i">
                    <Expression>s20*TNFa_TNFR-d0*TNFR.i</Expression>
                </DiffEqn>
                <DiffEqn symbol-ref="TNFa.m">
                    <Expression>t11*NFKB.n*NFKB.n-t7*TNFa.m</Expression>
                </DiffEqn>
                <!--    <Disabled>
        <Constant symbol="s0" value="1680"/>
    </Disabled>
-->
            </System>
            <Property symbol="NFKB" name="cytoplasm NF-KB " tags="cytoplasm" value="0"/>
            <Property symbol="NFKB.n" name="nucleus NF-KB" tags="nucleus" value="0.0"/>
            <Property symbol="IKK" tags="cytoplasm" value="0"/>
            <Property symbol="IKK_IKBA" tags="cytoplasm" value="0.0"/>
            <Property symbol="IKK_NFKB_IKBA" tags="cytoplasm" value="0.0"/>
            <Property symbol="NFKB_IKBA" name="cytoplasm NF-KB/IKBA complex" tags="cytoplasm" value="0.01"/>
            <Property symbol="NFKB_IKBA.n" name="nucelus NF-KB/IKBA complex" tags="nucleus" value="0.0"/>
            <Property symbol="IKBA" name="cytoplasm IKBA" tags="cytoplasm" value="0.0"/>
            <Property symbol="IKBA.n" name="nucleus IKBA" tags="nucleus" value="0.0"/>
            <Property symbol="IKBA.m" name="IKBA mRNA" tags="nucleus" value="0.0"/>
            <Property symbol="total_NFKB" value="NFKB+NFKB.n+IKK_NFKB_IKBA+NFKB_IKBA+NFKB_IKBA.n"/>
            <Property symbol="total_IKK" value="IKK+IKK_IKBA+IKK_NFKB_IKBA"/>
            <Property symbol="IKKconc" value="0.00075"/>
            <Property symbol="IKK_sum" value="0.0"/>
            <Property symbol="LPS" value="0.0"/>
            <Property symbol="stimulus" value="0.0"/>
            <Property symbol="iTNFa" name="internal TNFa" tags="cytoplasm" value="0.0"/>
            <Property symbol="eTNFa" name="external TNFa" tags="external" value="0.0"/>
            <Property symbol="TNFR" name="TNFa Receptor in cell membrane" tags="membrane" value="tmax"/>
            <Property symbol="TNFa_TNFR" name="complex of TNFa and TNFa Receptor" tags="membrane" value="0.0"/>
            <Property symbol="TNFR.i" name="internalized TNFa receptor" tags="cytoplasm" value="0.0"/>
            <Property symbol="TNFa.m" name="TNFa mRNA" tags="nucleus" value="0.0"/>
            <Property symbol="DTNF" value="1"/>
            <Property symbol="TNFaflux" value="0.0"/>
            <Property symbol="tmax" value="0.01"/>
            <Property symbol="order" value="0"/>
            <Property symbol="e1" value="4.4e-4*60"/>
            <Property symbol="s0" value="1680"/>
            <SurfaceConstraint target="0.1" strength="1" mode="aspherity"/>
            <VolumeConstraint target="500" strength="1"/>
            <Event compute-time="on-trigger">
                <Condition>(cell.id == activator) and time >= 0</Condition>
                <Rule symbol-ref="stimulus">
                    <Expression>0.5</Expression>
                </Rule>
            </Event>
            <Event compute-time="on-trigger">
                <Condition>(cell.id == activator) and time >= 60</Condition>
                <Rule symbol-ref="stimulus">
                    <Expression>0.0</Expression>
                </Rule>
            </Event>
            <NeighborhoodReporter>
                <Input scaling="length" value="(eTNFa-local.eTNFa)*DTNF"/>
                <Output symbol-ref="TNFaflux" mapping="average"/>
            </NeighborhoodReporter>
            <Property symbol="dist" value="distance(cell.center.x,cell.center.y)"/>
            <Function symbol="distance">
                <Expression>sqrt((x-96.87021277)^2+(y-106.4340426)^2)</Expression>
                <Parameter symbol="x"/>
                <Parameter symbol="y"/>
            </Function>
            <NeighborhoodReporter time-step="1.0">
                <Input noflux-cell-medium="false" scaling="cell" value="if(local.cell.id==activator,0,order+1)"/>
                <Output symbol-ref="order" mapping="minimum"/>
            </NeighborhoodReporter>
        </CellType>
        <CellType name="medium" class="medium">
            <System time-step="1.0" solver="Dormand-Prince [adaptive, O(5)]">
                <Rule symbol-ref="eTNFa">
                    <Expression>eTNFa+TNFaflux</Expression>
                </Rule>
            </System>
            <Property symbol="DTNF" value="0.9"/>
            <Property symbol="eTNFa" value="0.0"/>
            <Property symbol="TNFaflux" value="0.0"/>
            <Property symbol="order" value="1000000.0"/>
            <NeighborhoodReporter time-step="0.1">
                <Input scaling="length" value="(eTNFa-local.eTNFa)*DTNF"/>
                <Output symbol-ref="TNFaflux" mapping="average"/>
            </NeighborhoodReporter>
            <Property symbol="dist" value="100000000"/>
        </CellType>
    </CellTypes>
    <CellPopulations>
        <Population type="macrophage" size="1">
